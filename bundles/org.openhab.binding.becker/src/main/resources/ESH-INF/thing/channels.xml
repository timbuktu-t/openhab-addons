<?xml version="1.0" encoding="UTF-8"?>
<thing:thing-descriptions bindingId="becker"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:thing="http://eclipse.org/smarthome/schemas/thing-description/v1.0.0"
	xsi:schemaLocation="http://eclipse.org/smarthome/schemas/thing-description/v1.0.0 http://eclipse.org/smarthome/schemas/thing-description-1.0.0.xsd">

	<channel-group-type id="notification">
		<label>Notification</label>
		<description>Latest notification from Becker CentralControl.</description>
		<channels>
			<channel id="text" typeId="notificationText" />
			<channel id="time" typeId="notificationTime" />
		</channels>
	</channel-group-type>

	<channel-type id="notificationText" advanced="true">
		<item-type>String</item-type>
		<label>Text</label>
		<description>Text of the notification.</description>
		<category>Text</category>
		<state readOnly="true" />
		<config-description />
	</channel-type>

	<channel-type id="notificationTime" advanced="true">
		<item-type>DateTime</item-type>
		<label>Time</label>
		<description>Date and time of the notification.</description>
		<category>Time</category>
		<state readOnly="true" />
		<config-description />
	</channel-type>

	<channel-type id="window">
		<item-type>String</item-type>
		<label>Control</label>
		<description>Controls movement using up, down, stop and vent.</description>
		<category>Window</category>
		<state>
			<options>
				<option value="UP">Up</option>
                <option value="STOP">Stop</option>				
				<option value="DOWN">Down</option>
				<option value="VENT">Ventilate</option>
			</options>
		</state>
		<config-description />
	</channel-type>

	<channel-type id="blinds">
		<item-type>String</item-type>
		<label>Control</label>
		<description>Controls movement using up, down and stop.</description>
		<category>Blinds</category>
		<state>
			<options>
				<option value="UP">Up</option>
                <option value="STOP">Stop</option>				
				<option value="DOWN">Down</option>
			</options>
		</state>
		<config-description />
	</channel-type>

</thing:thing-descriptions>